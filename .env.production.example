# ============================================================================
# Production Environment Variables
# Naver Cloud Platform Deployment
# ============================================================================

# ============================================================================
# Application
# ============================================================================
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=https://aedpics.kr

# ============================================================================
# Database (Naver Cloud DB for PostgreSQL)
# ============================================================================
DATABASE_URL="postgresql://aedpics_admin:CHANGE_ME@{DB_HOST}.ncloud.com:5432/aedpics?schema=public&sslmode=require"

# ============================================================================
# Redis (Local Redis Server)
# ============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_PASSWORD=CHANGE_ME  # Uncomment if Redis auth enabled

# ============================================================================
# JWT Authentication
# ============================================================================
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d
JWT_ISSUER=aedpics
JWT_AUDIENCE=aedpics-users

# ============================================================================
# Email (SMTP)
# ============================================================================
# Gmail SMTP example
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password  # Use App Password, not account password
EMAIL_FROM="AED 점검 시스템 <noreply@aedpics.kr>"

# Alternative: Naver SMTP
# EMAIL_HOST=smtp.naver.com
# EMAIL_PORT=587
# EMAIL_USER=your-naver-id@naver.com
# EMAIL_PASSWORD=your-naver-password

# Alternative: SendGrid
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASSWORD=your-sendgrid-api-key

# ============================================================================
# Object Storage (Naver Cloud Platform)
# ============================================================================
OBJECT_STORAGE_ENDPOINT=https://kr.object.ncloudstorage.com
OBJECT_STORAGE_BUCKET=aedpics-uploads
OBJECT_STORAGE_ACCESS_KEY=CHANGE_ME
OBJECT_STORAGE_SECRET_KEY=CHANGE_ME
OBJECT_STORAGE_REGION=kr-standard

# ============================================================================
# Security: IP Whitelist
# ============================================================================
# Admin routes (/admin, /api/admin) - Required for admin access
# Format: Single IP, CIDR, or wildcard (comma-separated)
# Example: 203.xxx.xxx.xxx,10.0.0.0/8,192.168.*.*
ADMIN_IP_WHITELIST=203.xxx.xxx.xxx

# General access whitelist (optional, leave empty to allow all)
# IP_WHITELIST=10.0.0.0/8,192.168.0.0/16

# ============================================================================
# Security: Session Management
# ============================================================================
SESSION_TIMEOUT=1800  # 30 minutes in seconds

# ============================================================================
# File Upload
# ============================================================================
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_DIR=/home/aedpics/logs

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW=60  # seconds
RATE_LIMIT_MAX_REQUESTS=100  # requests per window

# ============================================================================
# Monitoring (Optional)
# ============================================================================
# Sentry (Error Tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# New Relic (APM)
# NEW_RELIC_LICENSE_KEY=your-license-key
# NEW_RELIC_APP_NAME=aedpics-production

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_2FA=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true

# ============================================================================
# Prisma
# ============================================================================
# Uncomment for Prisma Studio access
# PRISMA_STUDIO_PORT=5555

# ============================================================================
# Next.js
# ============================================================================
# Build optimization
NEXT_TELEMETRY_DISABLED=1

# ============================================================================
# PM2 (Process Manager)
# ============================================================================
PM2_INSTANCES=4  # Number of instances (max: number of CPU cores)
PM2_MAX_MEMORY_RESTART=1G

# ============================================================================
# Nginx
# ============================================================================
NGINX_CLIENT_MAX_BODY_SIZE=10M

# ============================================================================
# Backup
# ============================================================================
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=/home/aedpics/backups

# ============================================================================
# Notes
# ============================================================================
# 1. Replace all CHANGE_ME values with actual secrets
# 2. Never commit this file to Git (.env.production should be in .gitignore)
# 3. Use strong passwords (min 16 characters, mixed case, numbers, symbols)
# 4. Rotate secrets regularly (every 90 days recommended)
# 5. Store backups securely (encrypted, off-site)
#
# Security Checklist:
# - [ ] JWT_SECRET: 64+ random characters
# - [ ] DATABASE_URL: Strong password
# - [ ] OBJECT_STORAGE keys: Keep secret
# - [ ] ADMIN_IP_WHITELIST: Restrict to known IPs
# - [ ] EMAIL_PASSWORD: Use app-specific password
# - [ ] REDIS_PASSWORD: Enable if exposed
#
# For production deployment:
#   1. Copy this file: cp .env.production.example .env.production
#   2. Edit .env.production and set all values
#   3. Verify: node -e "require('dotenv').config({path:'.env.production'}); console.log(process.env.DATABASE_URL)"
#   4. Deploy: pm2 start ecosystem.config.js --env production
