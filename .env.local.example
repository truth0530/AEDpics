# 환경 설정
NODE_ENV=development

# PostgreSQL 데이터베이스 (Naver Cloud Platform)
DATABASE_URL="postgresql://username:password@host:5432/database?schema=public"

# Redis (Naver Cloud Platform)
REDIS_HOST=your-ncp-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT 인증
JWT_SECRET=your-very-secure-jwt-secret-minimum-32-characters
JWT_EXPIRES_IN=7d

# OTP 이메일 발송 (Nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=noreply@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=AED 점검 시스템 <noreply@example.com>

# 파일 업로드
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# 애플리케이션 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4 (선택사항)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Cron Job Secret (외부 요청 방지)
CRON_SECRET=your-cron-secret-key
